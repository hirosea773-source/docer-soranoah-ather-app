# Local Supabase / CI example
# GitHub Actions E2E uses a local Supabase instance started by `supabase start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_supabase_anon_key_here

# Local database URL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Production / Vercel
# Set production values in Vercel Environment Variables.
# Do not commit real production values.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_publishable_or_anon_key
# DATABASE_URL=postgresql://...
