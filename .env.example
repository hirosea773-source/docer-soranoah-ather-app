# --- Supabase Local Connection ---
# For browser development on host machine
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# For Playwright headless browser / tests inside Dev Container
NEXT_PUBLIC_SUPABASE_URL=http://supabase_kong_soranoah-authr-app:8000

# Shared Anon Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Database Connection ---
# For Drizzle ORM inside Dev Container
DATABASE_URL=postgresql://postgres:postgres@supabase_db_soranoah-authr-app:5432/postgres

# For direct connection from host machine
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
